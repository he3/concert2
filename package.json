{
  "name": "@he3-org/concert",
  "version": "1.8.0",
  "description": "Opinionated agentic development lifecycle orchestrator",
  "type": "module",
  "bin": {
    "concert": "./dist/cli.js"
  },
  "files": [
    "dist",
    "templates",
    ".claude/agents",
    "docs/concert/workflows",
    "docs/concert/templates",
    "docs/concert/stage-registry.jsonc",
    ".claude/skills",
    ".claude/rules",
    ".claude/commands/concert",
    ".github/agents",
    ".github/workflows/concert-ci.yml",
    ".github/workflows/concert-version-check.yml"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit && vitest run",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky"
  },
  "keywords": [
    "concert",
    "agentic",
    "development",
    "orchestration"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/he3-org/concert.git"
  },
  "engines": {
    "node": ">=18"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^2.0.0"
  },
  "lint-staged": {
    "*.{js,ts,css,md,json,jsonc}": [
      "prettier --write"
    ]
  }
}
